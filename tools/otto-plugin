#!/usr/bin/env bash
# otto-plugin — install / remove / sync custom Otto plugins.
#
# A plugin lives at $OTTO_PLUGINS_HOME/<slug> (default ~/otto-plugins) with an
# otto-plugin.toml manifest, a crate/ (Rust) and a ui/ (Svelte). This tool wires
# every enabled plugin into the build by REGENERATING (from scratch, so it is
# idempotent):
#   - crates/otto-plugins-host/Cargo.toml   (the OTTO-PLUGIN-DEPS block)
#   - crates/otto-plugins-host/src/registry.rs
#   - ui/src/plugins/registry.ts            (+ symlinks ui/src/plugins/<slug>)
#   - each plugin crate's otto-* dependency paths -> this repo
# It never edits core Otto code. After running, rebuild: cargo build -p ottod and
# (cd ui && npm run build).
#
# Usage:
#   otto-plugin install <git-url|local-path>   clone/copy into the plugins home, enable, sync
#   otto-plugin remove  <slug>                 disable + unlink, sync (keeps the files)
#   otto-plugin list                           show enabled/disabled plugins
#   otto-plugin sync                           regenerate all wiring from enabled plugins
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SCRIPT_DIR/.." && pwd)"
REPO_NAME="$(basename "$REPO")"
PLUGINS_HOME="${OTTO_PLUGINS_HOME:-$HOME/otto-plugins}"
HOST_CARGO="$REPO/crates/otto-plugins-host/Cargo.toml"
REGISTRY_RS="$REPO/crates/otto-plugins-host/src/registry.rs"
REGISTRY_TS="$REPO/ui/src/plugins/registry.ts"
UI_PLUGINS_DIR="$REPO/ui/src/plugins"

die() { echo "error: $*" >&2; exit 1; }

# toml_get <file> <key> — value of a top-level `key = "value"` line.
toml_get() { sed -n -E "s/^[[:space:]]*$2[[:space:]]*=[[:space:]]*\"([^\"]*)\".*/\1/p" "$1" | head -n1; }

ident() { echo "$1" | tr '-' '_'; }            # slug -> rust/crate identifier

# enabled plugin slugs: dirs under PLUGINS_HOME with a manifest and no .otto-disabled.
enabled_plugins() {
  [ -d "$PLUGINS_HOME" ] || return 0
  local d
  for d in "$PLUGINS_HOME"/*/; do
    [ -f "$d/otto-plugin.toml" ] || continue
    [ -f "$d/.otto-disabled" ] && continue
    basename "$d"
  done
}

regen() {
  local slugs=(); while IFS= read -r s; do [ -n "$s" ] && slugs+=("$s"); done < <(enabled_plugins)

  # ---- host Cargo.toml: regenerate the OTTO-PLUGIN-DEPS block ----------------
  local depfile; depfile="$(mktemp)"
  for s in "${slugs[@]:-}"; do
    [ -n "$s" ] || continue
    echo "$s = { path = \"../../../otto-plugins/$s/crate\" }" >> "$depfile"
  done
  awk -v blockfile="$depfile" '
    /OTTO-PLUGIN-DEPS:BEGIN/ { print; while ((getline l < blockfile) > 0) print l; close(blockfile); skip=1; next }
    /OTTO-PLUGIN-DEPS:END/   { skip=0 }
    !skip { print }
  ' "$HOST_CARGO" > "$HOST_CARGO.tmp" && mv "$HOST_CARGO.tmp" "$HOST_CARGO"
  rm -f "$depfile"

  # ---- registry.rs ----------------------------------------------------------
  {
    echo "//! GENERATED by tools/otto-plugin — do not edit by hand."
    echo "use axum::Router;"
    echo "use otto_core::Result;"
    echo "use otto_plugin_sdk::{PluginCtx, PluginManifest};"
    echo "use sqlx::SqlitePool;"
    echo
    echo "pub fn routers<S: PluginCtx>() -> Router<S> {"
    if [ "${#slugs[@]:-0}" -eq 0 ]; then
      echo "    Router::new()"
    else
      echo "    Router::new()"
      for s in "${slugs[@]}"; do echo "        .nest(\"/plugins/$s\", $(ident "$s")::router::<S>())"; done
    fi
    echo "}"
    echo
    echo "pub async fn migrate_all(pool: &SqlitePool) -> Result<()> {"
    [ "${#slugs[@]:-0}" -eq 0 ] && echo "    let _ = pool;"
    for s in "${slugs[@]:-}"; do [ -n "$s" ] && echo "    otto_plugin_sdk::run_migrations(pool, \"$s\", $(ident "$s")::MIGRATIONS).await?;"; done
    echo "    Ok(())"
    echo "}"
    echo
    echo "pub async fn start_all<S: PluginCtx>(ctx: S) -> Result<()> {"
    local n="${#slugs[@]:-0}" i=0
    if [ "$n" -eq 0 ]; then echo "    let _ = ctx;"; fi
    for s in "${slugs[@]:-}"; do
      [ -n "$s" ] || continue; i=$((i+1))
      if [ "$i" -lt "$n" ]; then echo "    $(ident "$s")::start(ctx.clone()).await?;";
      else echo "    $(ident "$s")::start(ctx).await?;"; fi
    done
    echo "    Ok(())"
    echo "}"
    echo
    echo "pub fn manifests() -> Vec<PluginManifest> {"
    if [ "${#slugs[@]:-0}" -eq 0 ]; then echo "    Vec::new()";
    else
      local list=""
      for s in "${slugs[@]}"; do list+="$(ident "$s")::manifest(), "; done
      echo "    vec![${list}]"
    fi
    echo "}"
  } > "$REGISTRY_RS"

  # ---- ui registry.ts + symlinks -------------------------------------------
  mkdir -p "$UI_PLUGINS_DIR"
  # drop stale plugin symlinks
  find "$UI_PLUGINS_DIR" -maxdepth 1 -type l -exec rm -f {} +
  {
    echo "// GENERATED by tools/otto-plugin — do not edit by hand."
    echo "import type { Component } from 'svelte';"
    local imports="" entries=""
    for s in "${slugs[@]:-}"; do
      [ -n "$s" ] || continue
      local dir="$PLUGINS_HOME/$s"
      local entry icon label
      entry="$(toml_get "$dir/otto-plugin.toml" entry)"; entry="${entry#ui/}"
      icon="$(toml_get "$dir/otto-plugin.toml" icon)"
      label="$(toml_get "$dir/otto-plugin.toml" name)"
      local id="${entry%.svelte}"
      ln -sfn "$dir/ui" "$UI_PLUGINS_DIR/$s"
      imports+="import $id from './$s/$entry';"$'\n'
      entries+="  { slug: '$s', label: '$label', icon: '$icon', permissionKey: '$s', component: $id },"$'\n'
    done
    printf "%s" "$imports"
    echo "export interface PluginEntry { slug: string; label: string; icon: string; permissionKey: string; component: Component<{ parts?: string[] }>; }"
    echo "export const PLUGINS: PluginEntry[] = ["
    printf "%s" "$entries"
    echo "];"
  } > "$REGISTRY_TS"

  # ---- rewrite each plugin crate's otto-* dep paths to THIS repo -------------
  for s in "${slugs[@]:-}"; do
    [ -n "$s" ] || continue
    local ct="$PLUGINS_HOME/$s/crate/Cargo.toml"
    [ -f "$ct" ] || continue
    sed -i.bak -E "s#(\.\./\.\./\.\./)[^/]+(/crates/)#\1$REPO_NAME\2#g" "$ct" && rm -f "$ct.bak"
  done

  echo "synced ${#slugs[@]:-0} plugin(s): ${slugs[*]:-(none)}"
  echo "rebuild:  cargo build -p ottod && (cd ui && npm run build)"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  install)
    src="${1:-}"; [ -n "$src" ] || die "usage: otto-plugin install <git-url|local-path>"
    mkdir -p "$PLUGINS_HOME"
    if [ -d "$src" ]; then
      slug="$(toml_get "$src/otto-plugin.toml" slug)"; [ -n "$slug" ] || die "no slug in $src/otto-plugin.toml"
      [ "$(cd "$src" && pwd)" = "$PLUGINS_HOME/$slug" ] || cp -R "$src" "$PLUGINS_HOME/$slug"
    else
      ( cd "$PLUGINS_HOME" && git clone "$src" )
      slug="$(basename "$src" .git)"
    fi
    rm -f "$PLUGINS_HOME/$slug/.otto-disabled"
    regen ;;
  remove)
    slug="${1:-}"; [ -n "$slug" ] || die "usage: otto-plugin remove <slug>"
    touch "$PLUGINS_HOME/$slug/.otto-disabled" 2>/dev/null || true
    rm -f "$UI_PLUGINS_DIR/$slug"
    regen ;;
  list)
    echo "plugins home: $PLUGINS_HOME"
    for d in "$PLUGINS_HOME"/*/; do
      [ -f "$d/otto-plugin.toml" ] || continue
      s="$(basename "$d")"
      [ -f "$d/.otto-disabled" ] && echo "  $s (disabled)" || echo "  $s (enabled)"
    done ;;
  sync) regen ;;
  *) die "usage: otto-plugin {install <src>|remove <slug>|list|sync}" ;;
esac
